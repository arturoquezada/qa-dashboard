<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Romi — Capacidad de Contratación</title>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --blue-900: #042C53; --blue-800: #0C447C; --blue-600: #185FA5;
    --blue-400: #378ADD; --blue-100: #B5D4F4; --blue-50: #E6F1FB;
    --green-800: #27500A; --green-600: #3B6D11; --green-50: #EAF3DE;
    --amber-800: #633806; --amber-600: #854F0B; --amber-50: #FAEEDA;
    --red-800: #791F1F; --red-600: #A32D2D; --red-50: #FCEBEB;
    --gray-900: #2C2C2A; --gray-600: #5F5E5A; --gray-200: #B4B2A9;
    --gray-100: #D3D1C7; --gray-50: #F1EFE8; --white: #FFFFFF;
    --bg: #F7F8FA; --surface: #FFFFFF; --border: rgba(0,0,0,0.08);
    --text: #1A1A18; --text-muted: #5F5E5A;
    --radius-sm: 6px; --radius-md: 10px; --radius-lg: 14px;
  }
  body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; line-height: 1.5; }

  header { background: var(--blue-900); padding: 1.25rem 2rem; display: flex; align-items: center; gap: 1rem; }
  .logo-mark { width: 36px; height: 36px; background: var(--blue-400); border-radius: var(--radius-sm); display: flex; align-items: center; justify-content: center; font-size: 15px; font-weight: 700; color: #fff; }
  .header-title { font-size: 16px; font-weight: 600; color: #fff; }
  .header-sub { font-size: 12px; color: var(--blue-100); margin-top: 1px; }
  .header-right { margin-left: auto; font-size: 12px; color: var(--blue-100); }

  .main { max-width: 1200px; margin: 0 auto; padding: 2rem 1.5rem; }

  .grid-campaign { display: grid; grid-template-columns: 380px 1fr; gap: 1.5rem; align-items: start; }

  .panel { background: var(--surface); border: 0.5px solid var(--border); border-radius: var(--radius-lg); padding: 1.5rem; }
  .panel-title { font-size: 12px; font-weight: 600; letter-spacing: 0.05em; text-transform: uppercase; color: var(--text-muted); margin-bottom: 1.25rem; }

  .slider-group { display: flex; flex-direction: column; gap: 1.25rem; }
  .slider-header { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 6px; }
  .slider-label { font-size: 14px; color: var(--text); }
  .slider-badge { font-size: 18px; font-weight: 600; color: var(--blue-600); min-width: 2.5rem; text-align: right; }
  .slider-desc { font-size: 11px; color: var(--text-muted); margin-top: 4px; }
  input[type=range] { -webkit-appearance: none; width: 100%; height: 4px; background: var(--gray-100); border-radius: 2px; outline: none; cursor: pointer; }
  input[type=range]::-webkit-slider-thumb { -webkit-appearance: none; width: 18px; height: 18px; background: var(--blue-600); border-radius: 50%; border: 2px solid #fff; box-shadow: 0 1px 4px rgba(0,0,0,0.2); }

  .campaign-grid { display: flex; flex-direction: column; gap: 8px; }
  .campaign-row { display: grid; grid-template-columns: 1fr 90px 90px; gap: 8px; align-items: center; padding: 10px 12px; border-radius: var(--radius-md); border: 0.5px solid var(--border); background: var(--bg); transition: background 0.15s; }
  .campaign-row:hover { background: var(--blue-50); }
  .campaign-row.inactive { opacity: 0.4; }
  .campaign-name { font-size: 13px; font-weight: 500; color: var(--text); display: flex; align-items: center; gap: 8px; }
  .camp-input { width: 100%; border: 0.5px solid var(--gray-100); border-radius: var(--radius-sm); padding: 5px 8px; font-size: 14px; font-weight: 600; color: var(--blue-800); text-align: center; background: var(--surface); }
  .camp-input:focus { outline: none; border-color: var(--blue-400); }
  .camp-label { font-size: 10px; color: var(--text-muted); text-align: center; margin-top: 2px; }
  .col-header { font-size: 10px; color: var(--text-muted); text-align: center; padding: 0 12px; }
  .col-headers { display: grid; grid-template-columns: 1fr 90px 90px; gap: 8px; margin-bottom: 4px; padding: 0 12px; }
  .toggle { width: 16px; height: 16px; border-radius: 3px; border: 1.5px solid var(--gray-200); background: var(--surface); cursor: pointer; appearance: none; flex-shrink: 0; }
  .toggle:checked { background: var(--blue-600); border-color: var(--blue-600); }

  .metrics-strip { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; margin-bottom: 1.25rem; }
  .metric { background: var(--blue-50); border-radius: var(--radius-md); padding: 0.9rem 1rem; }
  .metric-val { font-size: 26px; font-weight: 600; color: var(--blue-800); line-height: 1; }
  .metric-label { font-size: 12px; color: var(--blue-600); margin-top: 4px; }
  .metric-sub { font-size: 11px; color: var(--text-muted); margin-top: 2px; }

  .summary-bar { background: var(--blue-900); border-radius: var(--radius-md); padding: 1.1rem 1.25rem; display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin-bottom: 1.25rem; }
  .sum-item { text-align: center; }
  .sum-val { font-size: 26px; font-weight: 600; color: #fff; }
  .sum-label { font-size: 11px; color: var(--blue-100); margin-top: 2px; }

  /* Stack bar */
  .stack-wrap { background: var(--gray-50); border-radius: var(--radius-md); overflow: hidden; display: flex; height: 36px; margin-bottom: 0.75rem; }
  .stack-seg { display: flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 600; color: #fff; white-space: nowrap; overflow: hidden; transition: width 0.3s; }
  .stack-legend { display: flex; flex-wrap: wrap; gap: 12px; margin-bottom: 1.25rem; }
  .legend-item { display: flex; align-items: center; gap: 6px; font-size: 12px; color: var(--text-muted); }
  .legend-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }

  .camp-results { display: flex; flex-direction: column; gap: 8px; }
  .camp-result-row { display: grid; grid-template-columns: 160px 1fr 80px 80px 80px 90px; gap: 8px; align-items: center; padding: 10px 14px; border-radius: var(--radius-md); border: 0.5px solid var(--border); background: var(--surface); font-size: 13px; }
  .camp-result-header { background: var(--gray-50); font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.04em; color: var(--text-muted); }
  .camp-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
  .camp-name-cell { display: flex; align-items: center; gap: 8px; font-weight: 500; }
  .num { font-variant-numeric: tabular-nums; font-weight: 500; }
  .num-center { text-align: center; }

  .insights { display: flex; flex-direction: column; gap: 8px; }
  .insight { border-left: 3px solid; border-radius: 0 var(--radius-sm) var(--radius-sm) 0; padding: 10px 14px; font-size: 13px; line-height: 1.55; }
  .insight.green { background: var(--green-50); border-color: var(--green-600); color: var(--green-800); }
  .insight.amber { background: var(--amber-50); border-color: var(--amber-600); color: var(--amber-800); }
  .insight.blue  { background: var(--blue-50);  border-color: var(--blue-600);  color: var(--blue-800); }
  .insight strong { font-weight: 600; }

  .divider { border: none; border-top: 0.5px solid var(--border); margin: 1.25rem 0; }
  .chart-wrap { position: relative; width: 100%; height: 200px; margin-bottom: 0; }
  .footnote { font-size: 11px; color: var(--text-muted); margin-top: 0.5rem; }

  @media (max-width: 900px) {
    .grid-campaign { grid-template-columns: 1fr; }
    .metrics-strip { grid-template-columns: repeat(2, 1fr); }
    .camp-result-row { grid-template-columns: 1fr 1fr 1fr; }
    .summary-bar { grid-template-columns: 1fr; }
  }
</style>
</head>
<body>

<header>
  <div class="logo-mark">R</div>
  <div>
    <div class="header-title">Romi — Capacidad de Contratación</div>
    <div class="header-sub">EvolveCX · Carga acumulada del equipo de TA</div>
  </div>
  <div class="header-right">v3.0 · 2025</div>
</header>

<div class="main">
  <div class="grid-campaign">

    <div style="display:flex;flex-direction:column;gap:1.25rem;">
      <!-- Global params -->
      <div class="panel">
        <div class="panel-title">Capacidad del equipo</div>
        <div class="slider-group">
          <div>
            <div class="slider-header">
              <span class="slider-label">Entrevistas por día (todo el equipo)</span>
              <span class="slider-badge" id="cv-day">4</span>
            </div>
            <input type="range" id="cs-day" min="1" max="40" step="1" value="4">
            <div class="slider-desc">Suma de la capacidad de todos los reclutadores</div>
          </div>
          <div>
            <div class="slider-header">
              <span class="slider-label">Días de entrevistas / semana</span>
              <span class="slider-badge" id="cv-week">4</span>
            </div>
            <input type="range" id="cs-week" min="1" max="5" step="1" value="4">
          </div>
          <div>
            <div class="slider-header">
              <span class="slider-label">Días post-entrevista</span>
              <span class="slider-badge" id="cv-post">1</span>
            </div>
            <input type="range" id="cs-post" min="0" max="5" step="1" value="1">
            <div class="slider-desc">Oferta → aceptación → inicio (al final del stack)</div>
          </div>
        </div>
      </div>

      <!-- Campaign inputs -->
      <div class="panel">
        <div class="panel-title">Vacantes por campaña</div>
        <div class="col-headers">
          <div></div>
          <div class="col-header">Vacantes</div>
          <div class="col-header">Ratio</div>
        </div>
        <div class="campaign-grid" id="camp-inputs"></div>
      </div>

      <div class="panel">
        <div class="panel-title">Lecturas</div>
        <div class="insights" id="c-insights"></div>
      </div>
    </div>

    <div style="display:flex;flex-direction:column;gap:1.25rem;">
      <!-- Summary bar -->
      <div class="summary-bar" id="c-summary"></div>

      <!-- Stack bar -->
      <div class="panel">
        <div class="panel-title" style="margin-bottom:.75rem;">Stack de carga total — orden de ejecución</div>
        <div class="stack-wrap" id="stack-bar"></div>
        <div class="stack-legend" id="stack-legend"></div>
        <div class="footnote">Cada campaña se acumula sobre la anterior. El total es lo que tarda tu equipo en cubrir TODAS las vacantes, una detrás de otra con la misma capacidad diaria.</div>
      </div>

      <!-- Campaign detail table -->
      <div class="panel" style="padding:0;">
        <div style="padding:1.25rem 1.5rem .75rem;border-bottom:.5px solid var(--border);">
          <div class="panel-title" style="margin:0;">Detalle por campaña (dentro del stack)</div>
        </div>
        <div style="padding:1rem 1.25rem;">
          <div class="camp-results" id="c-results"></div>
        </div>
      </div>

      <!-- Chart -->
      <div class="panel" style="padding-bottom:1.25rem;">
        <div class="panel-title" style="margin-bottom:.75rem;">Entrevistas necesarias por campaña</div>
        <div class="chart-wrap"><canvas id="cChart"></canvas></div>
      </div>
    </div>
  </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<script>
const CAMPAIGNS = [
  { id: 'checkout',  name: 'Checkout / Signup', ratio: 3, color: '#185FA5' },
  { id: 'ace',       name: 'ACE / Loans',        ratio: 2, color: '#378ADD' },
  { id: 'cobranza',  name: 'Cobranza',           ratio: 4, color: '#854F0B' },
  { id: 'clivi',     name: 'Clivi / Cashmind',   ratio: 2, color: '#3B6D11' },
  { id: 'casap',     name: 'Casap',              ratio: 2, color: '#6D28D9' },
  { id: 'iforex',    name: 'iForex',             ratio: 5, color: '#A32D2D' },
];

let cChart;
const $ = id => document.getElementById(id);

function buildCampInputs() {
  const wrap = $('camp-inputs');
  wrap.innerHTML = CAMPAIGNS.map(c => `
    <div class="campaign-row" id="crow-${c.id}">
      <div class="campaign-name">
        <input type="checkbox" class="toggle" id="chk-${c.id}" checked onchange="renderCampaign()">
        <div style="width:8px;height:8px;border-radius:50%;background:${c.color};flex-shrink:0;"></div>
        <span>${c.name}</span>
      </div>
      <div>
        <input type="number" class="camp-input" id="vac-${c.id}" value="0" min="0" max="50" oninput="renderCampaign()">
        <div class="camp-label">vacantes</div>
      </div>
      <div>
        <input type="number" class="camp-input" id="rat-${c.id}" value="${c.ratio}" min="1" max="20" oninput="renderCampaign()">
        <div class="camp-label">ratio 1:N</div>
      </div>
    </div>
  `).join('');
}

function bindCampaign(slId, valId) {
  const sl = $(slId), vl = $(valId);
  sl.addEventListener('input', () => { vl.textContent = sl.value; renderCampaign(); });
}

function renderCampaign() {
  const perDay = +$('cs-day').value;
  const daysWk = +$('cs-week').value;
  const post   = +$('cs-post').value;

  CAMPAIGNS.forEach(c => {
    const row = $('crow-' + c.id);
    const checked = $('chk-' + c.id).checked;
    if (row) row.classList.toggle('inactive', !checked);
  });

  // Active campaigns with their interview load
  const active = CAMPAIGNS.filter(c => $('chk-' + c.id).checked).map(c => {
    const vac   = Math.max(0, parseInt($('vac-' + c.id).value) || 0);
    const ratio = Math.max(1, parseInt($('rat-' + c.id).value) || c.ratio);
    const ents  = vac * ratio;
    return { ...c, vac, ratio, ents };
  }).filter(c => c.vac > 0);

  const totalVac  = active.reduce((s, c) => s + c.vac, 0);
  const totalEnts = active.reduce((s, c) => s + c.ents, 0);

  // STACK LOGIC: cumulative days as we process campaign by campaign in sequence
  let cumEnts = 0;
  const stacked = active.map(c => {
    const startDay = Math.ceil(cumEnts / perDay);
    cumEnts += c.ents;
    const endDay = Math.ceil(cumEnts / perDay);
    return { ...c, startDay, endDay, daysUsed: endDay - startDay };
  });

  const totalDiasEntrevista = active.length ? Math.ceil(totalEnts / perDay) : 0;
  const totalDiasFinal = active.length ? totalDiasEntrevista + post : 0;
  const totalSemanas = (totalDiasEntrevista / daysWk).toFixed(1);

  // Summary
  $('c-summary').innerHTML = [
    { val: totalVac, label: 'Vacantes totales' },
    { val: totalEnts, label: 'Entrevistas necesarias' },
    { val: totalDiasFinal + 'd', label: `Tiempo total del equipo (~${totalSemanas} sem.)` },
  ].map(m => `<div class="sum-item"><div class="sum-val">${m.val}</div><div class="sum-label">${m.label}</div></div>`).join('');

  // Stack bar visualization
  if (!active.length) {
    $('stack-bar').innerHTML = `<div class="stack-seg" style="width:100%;background:var(--gray-200);color:var(--text-muted);">Agrega vacantes para ver el stack</div>`;
    $('stack-legend').innerHTML = '';
  } else {
    $('stack-bar').innerHTML = stacked.map(c => {
      const pct = Math.max(4, (c.ents / totalEnts) * 100);
      return `<div class="stack-seg" style="width:${pct}%;background:${c.color};" title="${c.name}: ${c.ents} entrevistas">${pct > 8 ? c.vac + ' vac.' : ''}</div>`;
    }).join('');
    $('stack-legend').innerHTML = stacked.map(c => `
      <div class="legend-item"><div class="legend-dot" style="background:${c.color}"></div>${c.name}: días ${c.startDay}–${c.endDay}</div>
    `).join('');
  }

  // Detail table — shows position in the stack
  $('c-results').innerHTML = `
    <div class="camp-result-row camp-result-header">
      <div>Campaña</div><div class="num-center">Vacantes</div><div class="num-center">Ratio</div><div class="num-center">Entrevistas</div><div class="num-center">Días en stack</div><div class="num-center">Rango (días)</div>
    </div>
    ${active.length ? stacked.map(c => `
      <div class="camp-result-row">
        <div class="camp-name-cell"><div class="camp-dot" style="background:${c.color}"></div>${c.name}</div>
        <div class="num num-center">${c.vac}</div>
        <div class="num num-center">1:${c.ratio}</div>
        <div class="num num-center">${c.ents}</div>
        <div class="num num-center">${c.daysUsed}</div>
        <div class="num num-center"><strong>${c.startDay}–${c.endDay}</strong></div>
      </div>
    `).join('') : '<div style="padding:1rem;font-size:13px;color:var(--text-muted);text-align:center;">Agrega vacantes para ver el detalle.</div>'}
  `;

  // Insights
  const insights = [];
  if (!active.length) {
    insights.push(`<div class="insight blue">Agrega vacantes en cualquier campaña para ver cuánto tiempo le toma a tu equipo cubrirlas todas.</div>`);
  } else {
    insights.push(`<div class="insight green">Tu equipo necesita <strong>${totalDiasFinal} días</strong> (${totalSemanas} semanas) para cubrir las <strong>${totalVac} vacantes</strong> activas, trabajando ${perDay} entrevistas/día.</div>`);
    const heaviest = active.reduce((a, b) => a.ents > b.ents ? a : b);
    insights.push(`<div class="insight amber"><strong>${heaviest.name}</strong> es la que más carga aporta al stack: ${heaviest.ents} de ${totalEnts} entrevistas totales (${Math.round(heaviest.ents/totalEnts*100)}%).</div>`);
    const costlyRatio = active.reduce((a, b) => a.ratio > b.ratio ? a : b);
    if (costlyRatio.ratio >= 4) {
      const r1 = costlyRatio.ratio - 1;
      const entsAhorradas = costlyRatio.vac * (costlyRatio.ratio - r1);
      const diasAhorrados = Math.ceil(entsAhorradas / perDay);
      insights.push(`<div class="insight blue">Si Romi mejora el filtro en <strong>${costlyRatio.name}</strong> (ratio 1:${costlyRatio.ratio} → 1:${r1}), tu equipo ahorra <strong>${diasAhorrados} día${diasAhorrados !== 1 ? 's' : ''}</strong> en el stack total.</div>`);
    }
  }
  $('c-insights').innerHTML = insights.join('');

  // Chart
  if (cChart) cChart.destroy();
  if (active.length) {
    cChart = new Chart($('cChart'), {
      type: 'bar',
      data: {
        labels: active.map(c => c.name),
        datasets: [{
          label: 'Entrevistas necesarias',
          data: active.map(c => c.ents),
          backgroundColor: active.map(c => c.color + '33'),
          borderColor: active.map(c => c.color),
          borderWidth: 2, borderRadius: 4
        }]
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        plugins: { legend: { display: false }, tooltip: { callbacks: { label: ctx => ` ${ctx.raw} entrevistas` } } },
        scales: {
          x: { grid: { display: false }, ticks: { font: { size: 11 }, color: '#5F5E5A' } },
          y: { beginAtZero: true, grid: { color: 'rgba(0,0,0,0.05)' }, ticks: { font: { size: 11 }, color: '#5F5E5A' } }
        }
      }
    });
  } else if (cChart) {
    cChart.destroy();
  }
}

buildCampInputs();
bindCampaign('cs-day',  'cv-day');
bindCampaign('cs-week', 'cv-week');
bindCampaign('cs-post', 'cv-post');
renderCampaign();
</script>
</body>
</html>
